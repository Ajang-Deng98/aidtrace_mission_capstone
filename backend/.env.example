# Database Configuration
DB_NAME=aidtrace_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432

# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-backend.azurewebsites.net,yourdomain.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Blockchain Configuration
BLOCKCHAIN_NETWORK=sepolia
SEPOLIA_CONTRACT_ADDRESS=0x394D38B35364BB63bF6497b925E9bEF6Bc056Be3
ALCHEMY_API_KEY=your_alchemy_key
BLOCKCHAIN_PRIVATE_KEY=0xyour_private_key
MNEMONIC=your twelve word mnemonic phrase

# Email Configuration
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Frontend URL (for password reset emails)
# Local: http://localhost:3000
# Deployed: https://aidtrace-southsudan.vercel.app
FRONTEND_URL=http://localhost:3000
